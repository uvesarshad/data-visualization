# Gemini / Google GenAI key. Any one of the three names below is accepted by Genkit.
GOOGLE_GENAI_API_KEY=add_api_here
# GEMINI_API_KEY=
# GOOGLE_API_KEY=

# Shared-secret token for /api/analyses/* (and future protected routes).
# When set, clients must POST this value to /api/auth/login to obtain a session cookie
# before they can list/create/update/delete saved analyses.
# Leave unset in local dev to disable the gate (a warning is logged).
# Recommended: 32+ random characters.
DATASENSE_API_TOKEN=
